# ═══════════════════════════════════════════════
# AlquilApp WhatsApp Bot — Variables de entorno
# Copiá este archivo como .env y completá los valores
# ═══════════════════════════════════════════════

# ── Twilio ──────────────────────────────────────
# Encontrás estos datos en: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Número de Twilio para WhatsApp (Sandbox: +14155238886)
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Google Gemini AI ────────────────────────────
# Obtené la clave en: aistudio.google.com/app/apikey
GEMINI_KEY=AIzaSy...

# ── Supabase ────────────────────────────────────
# Encontrás estos datos en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://rrgdwwaalozhsizngqrx.supabase.co
# ⚠️ Usar la clave SERVICE_ROLE (no la anon key) — NUNCA exponerla en el frontend
SUPABASE_SERVICE_KEY=eyJhbGci...

# ── Seguridad de notificaciones ─────────────────
# Contraseña para proteger el endpoint /notif-automaticas
# ⚠️ Generá un valor aleatorio propio (ej: openssl rand -hex 24) y rotalo si
# alguna vez usaste el valor que estaba publicado en versiones previas de este archivo.
NOTIF_SECRET=cambiame-por-un-valor-aleatorio-largo

# ── Proxy IA (opcional, recomendado) ─────────────
# Si se setea, los endpoints /ai/* exigen el header x-proxy-key con este valor.
AI_PROXY_SECRET=cambiame-por-otro-valor-aleatorio

# ── Puerto del servidor ─────────────────────────
PORT=3000
